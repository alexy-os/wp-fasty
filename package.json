{
  "name": "wp-fasty",
  "version": "1.0.0",
  "scripts": {
    "tokens": "bun run src/scripts/tokens/generate.ts",
    "tokens:hex": "bun run src/scripts/tokens/generate-hex.ts",
    "css": "tailwindcss -i ./src/styles/input.css -o ./wp-fasty-oop/theme.css",
    "css:watch": "tailwindcss -i ./src/styles/input.css -o ./wp-fasty-oop/theme.min.css --watch --minify",
    "css:build": "tailwindcss -i ./src/styles/input.css -o ./wp-fasty-oop/theme.min.css --minify",
    "scss": "sass wp-fasty-storefront/assets/scss/main.scss:wp-fasty-storefront/assets/css/theme.css",
    "scss:watch": "sass wp-fasty-storefront/assets/scss/main.scss:wp-fasty-storefront/assets/css/theme.css --watch",
    "scss:build": "sass wp-fasty-storefront/assets/scss/main.scss:wp-fasty-storefront/assets/css/theme.min.css --style=compressed",
    "build": "npm run tokens:hex && npm run scss:build"
  },
  "devDependencies": {
    "bun-types": "latest",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "tailwindcss": "3",
    "sass": "^1.58.0",
    "color-convert": "^2.0.1"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "postcss-nested": "^7.0.2"
  }
}